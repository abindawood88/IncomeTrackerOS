{
  "name": "dividend-freedom-pro",
  "version": "0.1.0",
  "private": true,
  "description": "Dividend income projection SaaS — Financial Independence Dashboard",
  "scripts": {
    "dev": "node node_modules/next/dist/bin/next dev",
    "build": "node node_modules/next/dist/bin/next build",
    "start": "node node_modules/next/dist/bin/next start",
    "lint": "node node_modules/next/dist/bin/next lint",
    "test": "node tests/run-tests.js",
    "test:watch": "nodemon --watch src/engine.js --watch tests --watch __tests__ --exec \"node tests/run-tests.js\"",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "verify": "npm test && npm run typecheck",
    "deploy:login": "vercel login",
    "deploy:preview": "vercel --yes",
    "deploy:prod": "vercel --prod"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.38.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.98.0",
    "clsx": "^2.1.1",
    "next": "^14.2.25",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^2.12.7",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.19",
    "eslint": "^8",
    "eslint-config-next": "^14.2.25",
    "nodemon": "^3.1.14",
    "playwright": "^1.58.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
